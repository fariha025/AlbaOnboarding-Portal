
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ALBA Onboarding</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#16246d" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>

    <!-- Background decorative elements -->
    <div class="bg-decoration">
        <div class="bg-circle bg-circle-1"></div>
        <div class="bg-circle bg-circle-2"></div>
        <div class="bg-circle bg-circle-3"></div>
        <div class="bg-grid"></div>
    </div>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-sm navbar-dark alba-navbar shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <div class="brand-icon">
                    <i class="fa-solid fa-industry"></i>
                </div>
                <span>ALBA Onboarding</span>
            </a>
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto ms-3 gap-1">
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="Admin" asp-action="Index">
                                <i class="fa-solid fa-gauge me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="Admin" asp-action="ManageUsers">
                                <i class="fa-solid fa-users me-1"></i>Manage Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="Admin" asp-action="Reports">
                                <i class="fa-solid fa-chart-bar me-1"></i>Reports
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill nav-invite" asp-controller="Admin" asp-action="InviteUser">
                                <i class="fa-solid fa-user-plus me-1"></i>Invite
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("HR"))
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="HR" asp-action="Dashboard">
                                <i class="fa-solid fa-gauge me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="HR" asp-action="Checklists">
                                <i class="fa-solid fa-list-check me-1"></i>Checklists
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Employee"))
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="Employee" asp-action="Dashboard">
                                <i class="fa-solid fa-house me-1"></i>My Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-controller="Employee" asp-action="Profile">
                                <i class="fa-solid fa-user me-1"></i>My Profile
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <div class="user-pill">
                                <i class="fa-solid fa-circle-user me-1"></i>
                                @User.Identity.Name
                            </div>
                        </li>
                        <li class="nav-item">
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                <button type="submit" class="btn btn-logout">
                                    <i class="fa-solid fa-right-from-bracket me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-login" asp-area="Identity" asp-page="/Account/Login">
                                <i class="fa-solid fa-right-to-bracket me-1"></i>Login
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4 pb-5 main-content">
        @RenderBody()
    </div>

    <footer class="alba-footer text-center py-3 mt-5">
        <small>
            <i class="fa-solid fa-industry me-1"></i>
            ALBA Onboarding Portal &copy; @DateTime.Now.Year &nbsp;|&nbsp;
            Aluminium Bahrain B.S.C.
        </small>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)

    <script>
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register('/sw.js');
            }
    </script>
    
</body>
</html>
