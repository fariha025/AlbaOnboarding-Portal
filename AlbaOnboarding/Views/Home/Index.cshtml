@{
    ViewData["Title"] = "Welcome";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div style="background: linear-gradient(135deg, #16246d 0%, #1e2d8a 50%, #5056d8 100%);
    color:white; padding:80px 20px 60px;
    margin:20px -12px 0; overflow:hidden; position:relative;">

    <div style="position:absolute;top:-100px;right:-100px;width:400px;height:400px;
    border-radius:50%;background:rgba(255,255,255,0.04)"></div>
    <div style="position:absolute;bottom:-80px;left:-80px;width:300px;height:300px;
    border-radius:50%;background:rgba(255,255,255,0.04)"></div>

    <div style="max-width:1100px;margin:0 auto;display:flex;
        align-items:center;justify-content:space-between;
        flex-wrap:wrap;gap:40px;position:relative;z-index:2">

        <div style="flex:1;min-width:300px;text-align:left">
            <div style="margin-bottom:20px">
                <img src="~/images/alba-logo.png" alt="ALBA Logo"
                     style="height:55px;filter:brightness(0) invert(1)"
                     onerror="this.style.display='none'" />
            </div>
            <div style="display:inline-block;background:rgba(255,255,255,0.12);
                border:1px solid rgba(255,255,255,0.2);
                border-radius:20px;padding:5px 14px;
                font-size:0.8rem;font-weight:500;
                margin-bottom:18px;letter-spacing:0.5px">
                HR & Training Department — ALBA
            </div>
            <h1 style="font-size:2.8rem;font-weight:800;line-height:1.15;
                margin-bottom:16px;letter-spacing:-0.5px">
                Employee Onboarding,<br />
                <span style="color:#abb8ff">Done Digitally.</span>
            </h1>
            <p style="font-size:1rem;opacity:0.85;line-height:1.8;
                margin-bottom:32px;max-width:460px">
                Replace paper checklists and manual coordination with a
                centralized portal. Invite employees, track progress,
                verify documents — all in one place.
            </p>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
                <a asp-area="Identity" asp-page="/Account/Login"
                       style="background:white;color:#16246d;padding:13px 30px;
                    border-radius:50px;text-decoration:none;
                    font-weight:700;font-size:0.95rem;
                    box-shadow:0 8px 24px rgba(0,0,0,0.2);
                    transition:all 0.2s">
                    Sign In to Portal →
                </a>
                <a href="#features"
                       style="background:rgba(255,255,255,0.12);color:white;
                    padding:13px 30px;border-radius:50px;
                    text-decoration:none;font-weight:600;
                    font-size:0.95rem;
                    border:1px solid rgba(255,255,255,0.25);
                    transition:all 0.2s">
                    Learn More
                </a>
            </div>
        </div>

        <div style="flex:1;min-width:300px;display:flex;
            justify-content:center;align-items:center;
            position:relative">
            <div style="position:absolute;width:380px;height:380px;
            border-radius:50%;
            background:radial-gradient(circle,
            rgba(80,86,216,0.5) 0%,
            rgba(22,36,109,0.1) 70%,
            transparent 100%);
            z-index:0"></div>
            <img src="~/images/image-1.png"
                 alt="Onboarding Illustration"
                 style="width:100%;
            height:100%;
            max-width:950px;
            object-fit:cover;
transform: scale (1.4);
            filter:drop-shadow(0 20px 30px rgba(0,0,0,0.2));
            opacity:1;
            position:relative;z-index:1" />
        </div>
    </div>
</div>
        <div style="max-width:1100px; margin:60px auto; padding: 0 20px;">
            <h3 style="text-align:center; color:#101042; margin-bottom:50px; font-size: 2.2rem; font-weight:700">
                Platform Features
            </h3>
    
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:40px">
        
                @{
                    var features = new[] {
                ("101042", "📋", "Digital Checklists", "Guided digital workflows organized by category — from Pre-Employment to IT Setup."),
                ("bd443c", "📁", "Secure Upload", "Verify and approve documents digitally with comments — no physical paperwork."),
                ("101042", "📊", "Real-Time Tracking", "Monitor onboarding progress live with dashboards and department-level analytics."),
                ("bd443c", "👥", "Role-Based Access", "Three distinct portals for Admin, HR Officers, and Employees."),
                ("101042", "✉️", "Email Invitations", "Invite new employees via secure email links with automatic role assignment."),
                ("bd443c", "✅", "Compliance Ready", "Full audit trail maintained for all mandatory ALBA documents.")
            };
                }

                @foreach (var feature in features)
                {
                    <div style="position: relative; padding-top: 25px;">
                        <div style="border: 2px solid #@feature.Item1; border-radius: 0 40px 40px 40px; padding: 40px 25px 25px; min-height: 150px; position: relative; background: white; box-shadow: 10px 10px 20px rgba(0,0,0,0.02);">
                    
                            <div style="position: absolute; top: -30px; left: -10px; width: 65px; height: 65px; background: white; border: 4px solid #@feature.Item1; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; box-shadow: 0 4px 10px rgba(0,0,0,0.1); z-index: 2;">
                                @feature.Item2
                            </div>

                            <h5 style="color:#@feature.Item1; margin-bottom:12px; font-weight:700; font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                @feature.Item3
                            </h5>
                            <p style="color:#555; font-size:0.95rem; line-height:1.6; margin:0;">
                                @feature.Item4
                            </p>
                        </div>
                
                        <div style="position: absolute; bottom: -5px; right: 20px; width: 60px; height: 5px; background: #@feature.Item1; opacity: 0.3; border-radius: 10px;"></div>
                    </div>
                }
            </div>
        </div>

<!-- How it works -->
<div style="max-width:900px;margin:48px auto 0">
    <h3 style="text-align:center;color:#101042;
        margin-bottom:28px;font-weight:500">
        How It Works
    </h3>
    <div style="display:flex;flex-wrap:wrap;
        justify-content:center;gap:0">

        @foreach (var step in new[] {
            ("1", "#101042", "Admin Invites", "Admin sends a secure invitation email to the new employee with their assigned role."),
            ("2", "#bd443c", "Employee Registers", "Employee clicks the link, creates their account and completes their profile."),
            ("3", "#101042", "Documents Uploaded", "Employee uploads all required documents organized by checklist category."),
            ("4", "#bd443c", "HR Reviews", "HR officer reviews each document and approves or rejects with feedback."),
            ("5", "#101042", "Onboarding Complete", "Once all documents approved, onboarding is marked complete and admin is notified.")
        })
        {
            <div style="text-align:center;padding:16px;
                min-width:160px;flex:1">
                <div style="width:48px;height:48px;border-radius:50%;
                    background:@step.Item2;color:white;
                    display:flex;align-items:center;
                    justify-content:center;font-size:1.3rem;
                    font-weight:600;margin:0 auto 10px">
                    @step.Item1
                </div>
                <h6 style="color:@step.Item2;font-weight:600;
                    margin-bottom:6px">
                    @step.Item3
                </h6>
                <p style="color:#777;font-size:0.82rem;
                    line-height:1.5;margin:0">
                    @step.Item4
                </p>
            </div>
        }

    </div>
</div>

<!-- Footer info -->
<div style="background:white;border-radius:12px;
    padding:24px;text-align:center;
    margin:40px 0;
    border-left:4px solid #101042;
    box-shadow:0 2px 8px rgba(0,0,117,0.08)">
    <h6 style="color:#101042;margin-bottom:6px;font-weight:600">
        For assistance contact HR & Training Department
    </h6>
    <p style="color:#888;font-size:0.88rem;margin:0">
        Aluminium Bahrain B.S.C. (ALBA) — HR & Training Department
        — Onboarding Portal
    </p>
</div>
