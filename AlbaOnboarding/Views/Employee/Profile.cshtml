@model AlbaOnboarding.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
}

<h2>My Profile</h2>
<p class="text-muted">Complete all fields to reach 100% profile completion.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- Profile completion bar -->
<div class="row">
    <div class="col-12 mb-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-1">
                    <span>Profile Completion</span>
                    <strong>@Model.ProfileCompletionPercent%</strong>
                </div>
                <div class="progress">
                    <div class="progress-bar"
                         style="width:@Model.ProfileCompletionPercent%;
                        background-color:#101042">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Photo upload — SEPARATE form, completely outside the profile form -->
<div class="card mb-4">
    <div class="card-header"><h5>Profile Photo</h5></div>
    <div class="card-body text-center">
        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <img src="@Model.PhotoPath"
                 style="width:100px;height:100px;border-radius:50%;
            object-fit:cover;border:3px solid #101042;
            margin-bottom:12px" />
            <br />
            <form asp-action="DeletePhoto" method="post"
                  style="display:inline">
                <button type="submit" class="btn btn-sm btn-danger mt-2"
                        onclick="return confirm(
                    'Are you sure you want to remove your profile photo?')">
                    Remove Photo
                </button>
            </form>
        }
        else
        {
            <div style="width:100px;height:100px;border-radius:50%;
                background:#e9ecef;margin:0 auto 12px;
                display:flex;align-items:center;
                justify-content:center;font-size:2rem;
                color:#101042">
                📷
            </div>
        }
        <form asp-action="UploadPhoto" method="post"
              enctype="multipart/form-data"
              style="margin-top:12px">
            <input type="file" name="photo" accept=".jpg,.jpeg,.png"
                   class="form-control form-control-sm mb-2"
                   style="max-width:260px;margin:0 auto" />
            <br />
            <button type="submit" class="btn btn-sm"
                    style="background:#101042;color:white">
                @(string.IsNullOrEmpty(Model.PhotoPath)
                    ? "Upload Photo" : "Replace Photo")
            </button>
        </form>
        <small class="text-muted d-block mt-1">JPG or PNG, max 2MB</small>
    </div>
</div>

<!-- Profile form — completely separate, no nested forms -->
<form asp-action="Profile" method="post">
    <div class="row">

        <!-- Left column -->
        <div class="col-md-6">

            <div class="card mb-3">
                <div class="card-header"><h5>Personal Information</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">
                            Employee Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="fullName" class="form-control"
                               value="@Model.FullName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            CPR / Passport No.
                        </label>
                        <input type="text" name="cprNumber" class="form-control"
                               value="@Model.CprNumber" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Badge Number</label>
                        <input type="text" name="badgeNumber" class="form-control"
                               value="@Model.BadgeNumber" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">PRF Number</label>
                        <input type="text" name="prfNumber" class="form-control"
                               value="@Model.PrfNumber" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Joining Date</label>
                        <input type="date" name="startDate" class="form-control"
                               value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><h5>Contact Information</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="text" class="form-control"
                               value="@Model.Email" disabled />
                        <small class="text-muted">Cannot be changed</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone Number</label>
                        <input type="text" name="phoneNumber" class="form-control"
                               value="@Model.PhoneNumber" />
                    </div>
                </div>
            </div>

        </div>

        <!-- Right column -->
        <div class="col-md-6">

            <div class="card mb-3">
                <div class="card-header"><h5>Employment Details</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">
                            Department <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="department" class="form-control"
                               value="@Model.Department" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Position Title <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="jobTitle" class="form-control"
                               value="@Model.JobTitle" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Grade</label>
                        <input type="text" name="grade" class="form-control"
                               value="@Model.Grade" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reference No.</label>
                        <input type="text" name="referenceNumber" class="form-control"
                               value="@Model.ReferenceNumber" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Source</label>
                        <select name="source" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var s in new[] { "Advert", "Agency", "Direct",
                            "Headhunting", "ALBA Website", "Exhibitions" })
                            {
                                <option value="@s"
                                        selected="@(Model.Source == s ? "selected" : null)">
                                    @s
                                </option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><h5>Review Information</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">
                            Prepared by (Recruitment Officer)
                        </label>
                        <input type="text" name="preparedBy" class="form-control"
                               value="@Model.PreparedBy" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Reviewed by (Head of Recruitment)
                        </label>
                        <input type="text" name="reviewedBy" class="form-control"
                               value="@Model.ReviewedByName" />
                    </div>
                </div>
            </div>

        </div>
    </div>

    <button type="submit" class="btn btn-dark px-4 mb-5">
        Save Profile
    </button>
</form>