@{
    ViewData["Title"] = "HR Dashboard";
}

<h2>HR Dashboard</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row mt-3">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h3>@ViewBag.TotalAssigned</h3>
                <p>Total Assigned</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h3>@ViewBag.Completed</h3>
                <p>Completed</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body text-center">
                <h3>@ViewBag.InProgress</h3>
                <p>In Progress</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-secondary">
            <div class="card-body text-center">
                <h3>@ViewBag.NotStarted</h3>
                <p>Not Started</p>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header"><h5>My Employees</h5></div>
    <div class="card-body">
        @if (ViewBag.EmployeeData == null ||
                    ((IEnumerable<dynamic>)ViewBag.EmployeeData).Count() == 0)
        {
            <p class="text-muted">
                No employees assigned to you yet.
                Ask the Admin to assign employees to your account.
            </p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th>Progress</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var data in ViewBag.EmployeeData)
                    {
                        var pct = (int)data.Percentage;
                        var barColor = pct < 30 ? "danger" :
                                       pct < 70 ? "warning" : "success";
                        <tr>
                            <td>
                                @data.Employee.FullName<br />
                                <small class="text-muted">@data.Employee.Email</small>
                                <br />
                                <span style="font-size:11px;font-weight:600;
                                    color:@(data.Percentage >= 70 ? "#1a6b2f" :
                                                                       data.Percentage >= 30 ? "#b45309" : "#8b1a14")">
                                    @data.Percentage% complete
                                </span>
                            </td>
                            <td>@data.Employee.Department</td>
                            <td>
                                <span class="badge bg-@(data.Employee.OnboardingStatus ==
                                                                                                              AlbaOnboarding.Models.OnboardingStatus.Completed ? "success" :
                                                                                                              data.Employee.OnboardingStatus ==
                                                                                                              AlbaOnboarding.Models.OnboardingStatus.InProgress ? "warning" :
                                                                                                              "secondary")">
                                    @data.Employee.OnboardingStatus
                                </span>
                            </td>
                            <td style="width:200px">
                                <div class="progress">
                                    <div class="progress-bar bg-@barColor"
                                         style="width:@pct%">
                                        @pct%
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a asp-action="ReviewEmployee"
                                   asp-route-employeeId="@data.Employee.Id"
                                   class="btn btn-sm btn-dark">Review</a>
                                @if (data.Employee.OnboardingStatus !=
                                                                    AlbaOnboarding.Models.OnboardingStatus.Completed)
                                {
                                    <form asp-action="CompleteOnboarding" method="post"
                                          style="display:inline">
                                        <input type="hidden" name="employeeId"
                                               value="@data.Employee.Id" />
                                        <button type="submit" class="btn btn-sm btn-success ms-1">
                                            Mark Complete
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
