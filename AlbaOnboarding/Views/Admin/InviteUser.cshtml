@{
    ViewData["Title"] = "Invite User";
}

<h2>Invite a New User</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["InviteLink"] != null)
{
    <div class="card mt-3" style="border-left:4px solid #5056d8">
        <div class="card-body">
            <p style="font-size:13px;font-weight:500;color:#16246d;margin-bottom:6px">
                Registration link (share manually if email fails):
            </p>
            <div style="display:flex;gap:8px;align-items:center">
                <input type="text" id="inviteLink"
                       class="form-control form-control-sm"
                       value="@TempData["InviteLink"]"
                       readonly />
                <button type="button" class="btn btn-sm btn-dark"
                        onclick="navigator.clipboard.writeText(
                    document.getElementById('inviteLink').value);
                    this.textContent='Copied!'">
                    Copy
                </button>
            </div>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mt-4" style="max-width:500px">
    <div class="card-body">
        <form asp-action="InviteUser" method="post">
            <div class="mb-3">
                <label class="form-label">Email address</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Role</label>
                <select name="role" class="form-select">
                    <option value="HR">HR</option>
                    <option value="Employee">Employee</option>
                </select>
            </div>
            <button type="submit" class="btn btn-dark">Send Invitation</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
