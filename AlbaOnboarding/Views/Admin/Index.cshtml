@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>Admin Dashboard</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<!-- Summary cards -->
<div class="row mt-3">
    <div class="col-md-2">
        <div class="card text-white bg-dark">
            <div class="card-body text-center">
                <h3>@ViewBag.TotalEmployees</h3>
                <p>Employees</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h3>@ViewBag.TotalHR</h3>
                <p>HR Officers</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h3>@ViewBag.Completed</h3>
                <p>Completed</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-warning">
            <div class="card-body text-center">
                <h3>@ViewBag.InProgress</h3>
                <p>In Progress</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-secondary">
            <div class="card-body text-center">
                <h3>@ViewBag.NotStarted</h3>
                <p>Not Started</p>
            </div>
        </div>
    </div>
    <div class="col-md-2 d-flex align-items-center">
        <a asp-action="InviteUser" class="btn btn-dark w-100">+ Invite User</a>
    </div>
</div>
<div class="mb-3">
    <input type="text" id="searchBox" class="form-control"
           placeholder="Search by name, email or department..."
           style="max-width:400px" />
</div>

@section Scripts {
    <script>
        document.getElementById('searchBox').addEventListener('keyup', function() {
            var val = this.value.toLowerCase();
            document.querySelectorAll('tbody tr').forEach(function(row) {
                row.style.display =
                    row.textContent.toLowerCase().includes(val) ? '' : 'none';
            });
        });
    </script>
}
<!-- All employees table -->
<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Employees</h5>
        <a asp-action="ExportCsv" class="btn btn-sm btn-outline-light">
            <i class="fa-solid fa-download me-1"></i>Export CSV
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Status</th>
                    <th>Progress</th>
                    <th>Assigned HR</th>
                    <th>Assign HR</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var data in ViewBag.EmployeeData)
                {
                    var pct = (int)data.Percentage;
                    var barColor = pct < 30 ? "#c0392b" :
                                   pct < 70 ? "#d97706" : "#1a6b2f";
                    <tr>
                        <!-- Name -->
                        <td>
                            <strong>@data.Employee.FullName</strong>
                            <br />
                            <small class="text-muted">
                                @data.Employee.Email
                            </small>
                        </td>

                        <!-- Department — inline editable dropdown -->
                        <td>
                            <form asp-action="AssignDepartment"
                                  method="post"
                                  style="display:flex;gap:4px;
                                align-items:center">
                                <input type="hidden" name="employeeId"
                                       value="@data.Employee.Id" />
                                <select name="department"
                                        class="form-select form-select-sm"
                                        style="min-width:130px;
                                    border:1px dashed #5056d8;
                                    background:#f9fafb"
                                        onchange="this.form.submit()">
                                    <option value="">
                                        @(string.IsNullOrEmpty(
                                            data.Employee.Department)
                                            ? "-- Set Department --"
                                            : data.Employee.Department)
                                    </option>
                                    @foreach (var dept in new[] {
                                        "Engineering", "Finance",
                                        "Operations", "HR", "IT",
                                        "Safety", "Procurement",
                                        "Legal", "Administration",
                                        "Production", "Maintenance",
                                        "Quality"
                                    })
                                    {
                                        if (dept != data.Employee.Department)
                                        {
                                            <option value="@dept">
                                                @dept
                                            </option>
                                        }
                                    }
                                </select>
                            </form>
                        </td>

                        <!-- Status -->
                        <td>
                            <span class="badge"
                                  style="background:@(
                                                                  data.Employee.OnboardingStatus ==
                                                                  AlbaOnboarding.Models.OnboardingStatus
                                                                      .Completed ? "#1a6b2f" :
                                                                  data.Employee.OnboardingStatus ==
                                                                  AlbaOnboarding.Models.OnboardingStatus
                                                                      .InProgress ? "#d97706" :
                                                                  "#64748b")">
                                @data.Employee.OnboardingStatus
                            </span>
                        </td>

                        <!-- Progress -->
                        <td style="min-width:120px">
                            <div class="progress" style="height:18px">
                                <div class="progress-bar"
                                     style="width:@pct%;
                                    background:@barColor;
                                    font-size:11px;
                                    font-weight:600">
                                    @pct%
                                </div>
                            </div>
                        </td>

                        <!-- Assigned HR display -->
                        <td>
                            @if (data.AssignedHRName == "Not Assigned")
                            {
                                <span class="badge"
                                      style="background:#888">
                                    Not Assigned
                                </span>
                            }
                            else
                            {
                                <span class="badge"
                                      style="background:#1a6b2f">
                                    ✓ @data.AssignedHRName
                                </span>
                            }
                        </td>

                        <!-- Assign HR — unchanged from before -->
                        <td>
                            <form asp-action="AssignHR" method="post"
                                  style="display:flex;gap:4px">
                                <input type="hidden" name="employeeId"
                                       value="@data.Employee.Id" />
                                <select name="hrId"
                                        class="form-select form-select-sm"
                                        style="min-width:120px">
                                    <option value="">-- Select HR --</option>
                                    @foreach (var hr in ViewBag.HRList)
                                    {
                                        <option value="@hr.Id"
                                                selected="@(
                                                                                        data.Employee.AssignedHRId
                                                                                        == hr.Id
                                                                                        ? "selected" : null)">
                                            @hr.FullName
                                        </option>
                                    }
                                </select>
                                <button type="submit"
                                        class="btn btn-sm btn-dark">
                                    Assign
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>